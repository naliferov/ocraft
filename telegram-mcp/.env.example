# Telegram MTProto credentials for the telegram-mcp server.
# Get TG_API_ID and TG_API_HASH from https://my.telegram.org -> "API development tools".
# This is a USER account session (reads your channels/private chats) — NOT the bot token.
TG_API_ID=
TG_API_HASH=

# Filled in automatically by `npm run login`. Leave blank initially.
TG_SESSION=
