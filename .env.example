# ocraft environment — copy this to `.env` and fill in. `.env` is gitignored; THIS file is the
# committed template. Single-user, local-first — nothing here is required to run.

# --- Server (all optional; shown with their defaults) -------------------------
# PORT=3001                 # api port
# BIND_HOST=127.0.0.1       # 0.0.0.0 for LAN access, or the prod :80 bind behind a proxy
# MAX_BODY_BYTES=1048576    # request body size cap
# NODE_ENV=production       # PROD: adds HSTS; the dev-only /api/claude endpoint stays off

# --- Optional features --------------------------------------------------------
# BIN_REGISTRY_DIR=         # dir of media served by bare name on /api/bin/:name (vlang i<alias>); dev only
# TELEGRAM_BOT_TOKEN=       # for the telegram tasks / MCP, if you use them
