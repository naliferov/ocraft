# ocraft environment — copy this to `.env` and fill in. `.env` is gitignored; THIS file is the
# committed template. Multi-user mode needs DATABASE_URL (auth + the node store live in Postgres).
# Sign-in is email+password by default; Google is OPTIONAL — set the GOOGLE_* vars to add the button.
# Full setup walkthrough: README → "Multi-user — Postgres sign-in". The old API_TOKEN is gone.

# --- Postgres (node store + users/sessions) -----------------------------------
# Local dev — a Docker container is easiest:
#   docker run -d --name ocraft-pg -e POSTGRES_PASSWORD=ocraft -e POSTGRES_DB=ocraft -p 5432:5432 postgres:16
# Prod — a native `apt install postgresql` on the box (not Docker).
DATABASE_URL=postgresql://postgres:ocraft@localhost:5432/ocraft

# --- Google sign-in (OPTIONAL) ------------------------------------------------
# Leave this whole block unset to run pure email+password — the "Sign in with Google" button only
# appears when BOTH vars below are present. To enable Google: Google Cloud Console → APIs & Services
# → Credentials → OAuth client ID → "Web application". Use a SEPARATE client per environment:
#   dev  → Authorized redirect URI  http://localhost:5173/api/auth/google/callback
#   prod → Authorized redirect URI  https://<your-domain>/api/auth/google/callback
# The Client ID is public; keep the secret out of git (Google auto-revokes leaked secrets).
# NOTE: prod (NODE_ENV=production) is Google-ONLY — email sign-in is off there, and it fails closed
# without a working Google client.
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# The app's public origin — used ONLY to build the Google redirect_uri (needed only if you enable
# Google). Dev MUST set it to the Vite port (the proxy otherwise makes the api see its own :3001
# host). Prod behind Cloudflare/Caddy can usually omit it (the forwarded headers are correct).
# APP_ORIGIN=http://localhost:5173

# --- Server (all optional; shown with their defaults) -------------------------
# PORT=3001                 # api port
# BIND_HOST=127.0.0.1       # 0.0.0.0 for LAN access, or the prod :80 bind behind a proxy
# MAX_BODY_BYTES=1048576    # request body size cap
# NODE_ENV=production       # PROD: Secure cookies + HSTS, and fails closed if Google isn't configured
# COOKIE_SECURE=true        # force Secure cookies without NODE_ENV=production (e.g. behind TLS)

# --- Optional features --------------------------------------------------------
# TELEGRAM_BOT_TOKEN=       # for the telegram tasks / MCP, if you use them
