# gcal-mcp auth — service account (read-only Calendar access).
# 1. Create a service account in Google Cloud Console (APIs & Services ->
#    Credentials), with the Google Calendar API enabled, and download a JSON key.
# 2. Share the target calendar with the service account's email
#    (Calendar settings -> Share with specific people -> "See all event details").
# 3. Point GOOGLE_APPLICATION_CREDENTIALS at the JSON key (keep it out of git).
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Calendar to read. Service accounts have no useful "primary", so set this explicitly.
GOOGLE_CALENDAR_ID=you@gmail.com
