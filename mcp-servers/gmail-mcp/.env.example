# gmail-mcp auth — read-only Gmail access over IMAP via an app password.
# 1. Turn on 2-Step Verification: https://myaccount.google.com/security
# 2. Create an app password: https://myaccount.google.com/apppasswords
#    (pick "Mail" / "Other"; Google shows a 16-char password — paste it below,
#     spaces optional).
# 3. IMAP is on by default for all Gmail accounts (nothing to enable).
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
